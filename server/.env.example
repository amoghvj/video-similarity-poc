# ─── Embedding Backend ────────────────────────────────────────────────────────
# Which embedding service to use. Options:
#   gemini-key   → Gemini API key (free tier, no GCP billing needed) [default]
#   gemini       → Vertex AI multimodalembedding@001 (requires GCP billing)
#   clip         → Local CLIP model (offline, no API key needed)
EMBEDDING_BACKEND=gemini-key

# ─── Gemini API Key (required when EMBEDDING_BACKEND=gemini-key) ──────────────
# Get a free key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ─── Vertex AI (required when EMBEDDING_BACKEND=gemini) ──────────────────────
# Your GCP project ID with Vertex AI API enabled and billing active.
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
VERTEX_LOCATION=us-central1

# ─── Detection Settings ───────────────────────────────────────────────────────
# Number of frames extracted from the INPUT video (more = more accurate, slower)
N_FRAMES=3

# Number of frames extracted from each CANDIDATE video (see note below)
# 0 = thumbnail only (fast, ~1 API call per candidate)
# 1+ = thumbnail + N frames (frame-vs-frame comparison, more accurate but slower)
CANDIDATE_FRAMES=0

# Cosine similarity threshold to flag a video as a match (0.0 – 1.0)
SIMILARITY_THRESHOLD=0.85

# Maximum number of YouTube candidate videos to compare against
MAX_CANDIDATES=10
